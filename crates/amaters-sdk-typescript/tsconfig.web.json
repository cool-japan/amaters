{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist/web",
    "noEmit": false,
    "declaration": false,
    "allowImportingTsExtensions": false
  },
  "include": ["src/ts/**/*"],
  "exclude": ["node_modules", "dist", "pkg", "examples"]
}
